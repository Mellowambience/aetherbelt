# AETHERBELT local secrets — COPY THIS FILE TO .env AND FILL IT IN.
# .env is gitignored. NEVER commit the real .env.
#
# Pick ONE auth method:
#
# Method 1 — static bearer (simplest):
# X_BEARER_TOKEN=your-user-context-access-token
#
# Method 2 — OAuth 2.0 user-context (recommended; mints a short-lived bearer per post):
# X_CLIENT_ID=your_oauth2_client_id
# X_CLIENT_SECRET=your_oauth2_client_secret
# X_REFRESH_TOKEN=your_long_lived_refresh_token
